{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "crossr-skills features.json Schema",
  "description": "Schema for the phase/commits/features tracking format used by the crossr-skills harness.",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": ["pending", "in_progress", "completed", "verified"]
      },
      "commits": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "status": {
              "type": "string",
              "enum": ["pending", "in_progress", "completed"]
            },
            "features": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["id", "title", "status"]
        }
      }
    },
    "required": ["status", "commits"]
  }
}