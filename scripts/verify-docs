#!/usr/bin/env bash
#
# verify-docs
# Basic mechanical verification of the project's documentation.
#
# Usage: ./scripts/verify-docs
#
# This is the foundation for documentation quality gates in the harness.
# It will be expanded in subsequent PRs with more sophisticated checks.

set -euo pipefail

echo "→ Running documentation verification..."

FAILED=0

# 1. Verify mdBook builds cleanly (if mdbook is available)
echo ""
echo "Checking mdBook documentation..."
if command -v mdbook >/dev/null 2>&1; then
    if cd book && mdbook build > /dev/null 2>&1; then
        echo "  ✓ mdBook builds successfully"
    else
        echo "  ✗ mdBook build failed"
        FAILED=1
    fi
    cd - > /dev/null
else
    echo "  (mdbook not installed — skipping)"
fi

# 2. Verify Zola site builds cleanly (if zola is available)
echo ""
echo "Checking Zola marketing site..."
if command -v zola >/dev/null 2>&1; then
    if cd site && zola build --force > /dev/null 2>&1; then
        echo "  ✓ Zola site builds successfully"
    else
        echo "  ✗ Zola site build failed"
        FAILED=1
    fi
    cd - > /dev/null
else
    echo "  (zola not installed — skipping)"
fi

# 3. Post-remediation drift checks (expanded in dv-02)
echo ""
echo "Running post-remediation drift checks..."

# Ensure the canonical Harness Relationship (Stratified) principle is documented
if grep -q "Harness Relationship (Stratified)" HARNESS-SPEC.md; then
    echo "  ✓ HARNESS-SPEC.md references Harness Relationship (Stratified) principle"
else
    echo "  ✗ HARNESS-SPEC.md missing Harness Relationship (Stratified) principle"
    FAILED=1
fi

# Ensure AGENTS.md mentions the canonical structure
if grep -q "canonical portable structure" AGENTS.md; then
    echo "  ✓ AGENTS.md references canonical portable structure"
else
    echo "  ✗ AGENTS.md missing reference to canonical portable structure"
    FAILED=1
fi

# Ensure the skills overview in the book reflects the new standards
if grep -q "Harness Relationship (Stratified)" book/src/skills/overview.md; then
    echo "  ✓ book/src/skills/overview.md references Harness Relationship (Stratified)"
else
    echo "  ✗ book/src/skills/overview.md missing Harness Relationship (Stratified) reference"
    FAILED=1
fi

# Check for inappropriate ferro-wg leakage in active docs (outside remediation reports)
if grep -r "ferro-wg" --include="*.md" book/ site/content/ 2>/dev/null | grep -v remediation | grep -v "proven on ferro-wg" | grep -q .; then
    echo "  ✗ Found potential ferro-wg leakage in book/ or site/ documentation"
    FAILED=1
else
    echo "  ✓ No inappropriate ferro-wg leakage detected in active docs"
fi

# Basic existence checks for key files (kept from dv-01)
if [ -f "book/src/skills/overview.md" ] && [ -f "HARNESS-SPEC.md" ] && [ -f "AGENTS.md" ]; then
    echo "  ✓ Key documentation files present"
else
    echo "  ✗ One or more key documentation files missing"
    FAILED=1
fi

echo ""
if [ $FAILED -eq 0 ]; then
    echo "✓ All documentation verification checks passed."
    exit 0
else
    echo "✗ Documentation verification failed."
    exit 1
fi
